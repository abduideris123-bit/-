<!DOCTYPE html>
<html lang="am">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="theme-color" content="#16A34A"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-title" content="бҢҚбүҘбҲӯбҠ“ бҲұбү…"/>
<title>рҹҢұ бҢҚбүҘбҲӯбҠ“ бҲұбү…</title>
<link rel="manifest" id="mp"/>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:'Noto Sans Ethiopic','Segoe UI',sans-serif;background:#F0FDF4;color:#1C2B1A;min-height:100vh;padding-bottom:84px;}
input,select,button{font-family:inherit;}
.hdr{background:linear-gradient(135deg,#16A34A,#15803D);padding:12px 20px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px #00000022;}
.hdr-in{max-width:560px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;}
.hdr h1{font-size:18px;font-weight:800;color:#fff;}
.hdr .sub{font-size:11px;color:#BBF7D0;margin-top:1px;}
.out-btn{background:#ffffff22;border:none;color:#fff;border-radius:8px;padding:5px 10px;font-size:12px;cursor:pointer;}
.main{max-width:560px;margin:0 auto;padding:14px;}
.card{background:#fff;border-radius:16px;padding:16px;border:1px solid #BBF7D0;box-shadow:0 2px 8px #00000008;margin-bottom:12px;}
.card.warn{background:#FEF2F2;border-color:#EF444433;}
.card.gold{background:#FEF9C3;border-color:#CA8A0433;}
.card.grn{background:#DCFCE7;border-color:#16A34A33;}
.card.exp{background:#FFF1F2;border-color:#FB7185;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
.sv{font-size:17px;font-weight:800;}
.sv.g{color:#16A34A;}.sv.go{color:#CA8A04;}.sv.a{color:#15803D;}.sv.r{color:#EF4444;}
.sl{font-size:11px;color:#6B7280;margin-top:2px;}
.st{font-size:13px;font-weight:700;color:#15803D;margin-bottom:10px;}
.row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid #BBF7D0;font-size:13px;}
.row:last-child{border-bottom:none;}
.rn{font-weight:600;}.rs{font-size:11px;color:#6B7280;margin-top:1px;}.rv{font-size:14px;font-weight:800;color:#16A34A;}
.wr{display:flex;justify-content:space-between;font-size:12px;padding:4px 0;border-bottom:1px solid #EF444411;}
.wv{font-weight:700;color:#EF4444;}
.inp{width:100%;border:1.5px solid #BBF7D0;border-radius:10px;padding:9px 12px;font-size:14px;color:#1C2B1A;outline:none;background:#fff;margin-bottom:9px;}
.inp:focus{border-color:#16A34A;}
.lbl{font-size:11px;font-weight:600;color:#6B7280;margin-bottom:3px;}
.btn{padding:9px 16px;border-radius:10px;border:none;font-size:13px;font-weight:700;cursor:pointer;}
.btn.p{background:#16A34A;color:#fff;}
.btn.d{background:#EF4444;color:#fff;}
.btn.g{background:#F3F4F6;color:#374151;}
.btn.full{width:100%;padding:13px;font-size:15px;}
.fr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:4px;}
.cat-card{background:#fff;border-radius:16px;padding:16px 12px;border:2px solid #BBF7D0;cursor:pointer;text-align:center;transition:all 0.15s;box-shadow:0 2px 8px #00000008;}
.cat-card:active{transform:scale(0.96);}
.cat-icon{font-size:30px;margin-bottom:5px;}
.cat-name{font-size:13px;font-weight:700;}
.cat-count{font-size:11px;color:#6B7280;margin-top:2px;}
.back-btn{display:flex;align-items:center;gap:6px;background:transparent;border:none;color:#16A34A;font-size:14px;font-weight:700;cursor:pointer;margin-bottom:12px;padding:0;}
.pi{background:#fff;border-radius:14px;padding:12px;border:1px solid #BBF7D0;display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.pi.exp-soon{border-color:#FB7185;background:#FFF1F2;}
.pi.expired{border-color:#EF4444;background:#FEE2E2;}
.pic{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.pinfo{flex:1;min-width:0;}
.pname{font-weight:700;font-size:14px;}
.pcat{font-size:11px;color:#6B7280;margin-top:1px;}
.pqty{font-size:11px;margin-top:2px;}
.pqty .q{font-weight:700;color:#16A34A;}.pqty .q.low{color:#EF4444;}
.pexp{font-size:10px;margin-top:2px;font-weight:600;}
.pexp.ok{color:#16A34A;}.pexp.soon{color:#F59E0B;}.pexp.expired{color:#EF4444;}
.pact{display:flex;flex-direction:column;gap:5px;flex-shrink:0;}
.ib{border:none;border-radius:8px;width:32px;height:32px;cursor:pointer;font-size:13px;}
.ib.e{background:#F3F4F6;}.ib.dl{background:#FEF2F2;}
.si{background:#fff;border-radius:14px;padding:12px;border:1px solid #BBF7D0;margin-bottom:8px;}
.sh{display:flex;justify-content:space-between;align-items:flex-start;}
.sn{font-weight:700;font-size:14px;}.sm{font-size:11px;color:#6B7280;margin-top:2px;}
.st2{font-size:15px;font-weight:800;color:#16A34A;}.sp{font-size:10px;color:#15803D;}
.sact{display:flex;gap:5px;margin-top:8px;border-top:1px solid #BBF7D0;padding-top:8px;}
.bnav{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #BBF7D0;padding:5px 12px 10px;box-shadow:0 -4px 20px #00000010;}
.bnav-in{max-width:560px;margin:0 auto;display:flex;gap:4px;}
.nb{flex:1;padding:7px 2px;border:none;border-radius:11px;background:transparent;color:#6B7280;font-size:10px;font-weight:700;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;}
.nb.active{background:#16A34A;color:#fff;}
.ni{font-size:18px;}
.mbg{position:fixed;inset:0;background:#00000066;z-index:200;display:flex;align-items:flex-end;justify-content:center;}
.mod{background:#fff;border-radius:20px 20px 0 0;padding:22px 18px 30px;width:100%;max-width:560px;max-height:88vh;overflow-y:auto;}
.mt{font-size:16px;font-weight:800;margin-bottom:16px;}
.ma{display:flex;gap:10px;margin-top:8px;}
.cmod-bg{position:fixed;inset:0;background:#00000066;z-index:200;display:flex;align-items:center;justify-content:center;padding:20px;}
.cmod{background:#fff;border-radius:18px;padding:22px;width:100%;max-width:340px;text-align:center;}
.cmod .bi{font-size:38px;margin-bottom:10px;}
.cmod h3{font-size:15px;font-weight:700;margin-bottom:7px;}
.cmod p{font-size:12px;color:#6B7280;margin-bottom:18px;}
.ca{display:flex;gap:10px;}
.tp{background:#DCFCE7;border:1px solid #BBF7D0;border-radius:10px;padding:9px 13px;margin-bottom:12px;font-size:13px;}
.tp strong{color:#16A34A;}
.toast{position:fixed;bottom:92px;left:50%;transform:translateX(-50%);background:#1C2B1A;color:#fff;border-radius:12px;padding:9px 18px;font-size:13px;font-weight:600;z-index:300;white-space:nowrap;box-shadow:0 4px 20px #00000044;}
.empty{color:#9CA3AF;font-size:13px;text-align:center;padding:28px;}
/* exp alert banner */
.exp-banner{background:#FFF1F2;border:1.5px solid #FB7185;border-radius:14px;padding:12px 14px;margin-bottom:12px;}
.exp-banner .etitle{font-size:13px;font-weight:700;color:#EF4444;margin-bottom:8px;}
.exp-row{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px solid #FEE2E2;}
.exp-row:last-child{border-bottom:none;}
.lbg{min-height:100vh;background:linear-gradient(160deg,#16A34A,#15803D 60%,#052e16);display:flex;align-items:center;justify-content:center;padding:20px;}
.lcard{background:#fff;border-radius:22px;padding:34px 26px;width:100%;max-width:360px;box-shadow:0 20px 60px #00000044;}
.llogo{text-align:center;margin-bottom:24px;}
.llogo .em{font-size:50px;margin-bottom:6px;}
.llogo h2{font-size:22px;font-weight:800;color:#15803D;}
.llogo p{font-size:12px;color:#6B7280;margin-top:3px;}
.ibox{background:#DCFCE7;border:1px solid #BBF7D0;border-radius:11px;padding:9px 13px;font-size:12px;color:#15803D;margin-bottom:16px;line-height:1.6;}
.err{color:#EF4444;font-size:12px;margin-top:-6px;margin-bottom:7px;}
.rr{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #BBF7D0;font-size:13px;}
.rr span:first-child{color:#6B7280;}.rr span:last-child{font-weight:700;}
select.inp{appearance:auto;}
.badge{display:inline-block;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700;}
.badge.exp{background:#FEE2E2;color:#EF4444;}
.badge.soon{background:#FEF9C3;color:#CA8A04;}
.detail-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid #BBF7D0;font-size:13px;}
.detail-row:last-child{border-bottom:none;}
.detail-label{color:#6B7280;font-size:12px;}
.detail-val{font-weight:700;font-size:13px;}
.desc-box{background:#F0FDF4;border:1px solid #BBF7D0;border-radius:10px;padding:10px 12px;font-size:13px;color:#1C2B1A;line-height:1.7;margin-top:4px;}
/* Product grid cards */
.prod-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:4px;}
.pg-card{background:#fff;border-radius:14px;padding:12px 10px;border:1px solid #BBF7D0;box-shadow:0 2px 8px #00000008;cursor:pointer;position:relative;transition:all 0.15s;}
.pg-card:active{transform:scale(0.97);}
.pg-card.exp-soon{border-color:#FB7185;}
.pg-card.expired{border-color:#EF4444;background:#FEF2F2;}
.pg-badge{display:inline-block;background:#16A34A;color:#fff;border-radius:6px;padding:2px 7px;font-size:10px;font-weight:700;margin-bottom:6px;}
.pg-name{font-size:12px;font-weight:700;color:#1C2B1A;margin-bottom:6px;line-height:1.3;min-height:32px;}
.pg-price{font-size:14px;font-weight:800;color:#16A34A;margin-bottom:4px;}
.pg-unit{font-size:10px;color:#6B7280;}
.pg-exp{font-size:9px;font-weight:600;margin-top:4px;}
.pg-exp.ok{color:#16A34A;}.pg-exp.soon{color:#F59E0B;}.pg-exp.expired{color:#EF4444;}
.pg-qty{font-size:10px;color:#6B7280;margin-top:2px;}
.pg-qty.low{color:#EF4444;font-weight:700;}
.pg-actions{display:flex;gap:4px;margin-top:8px;border-top:1px solid #F0FDF4;padding-top:8px;}
.pg-btn{flex:1;border:none;border-radius:7px;padding:5px 2px;font-size:11px;font-weight:700;cursor:pointer;}
.pg-btn.e{background:#F3F4F6;color:#374151;}
.pg-btn.d{background:#FEF2F2;color:#EF4444;}
.install-bar{position:fixed;bottom:84px;left:0;right:0;z-index:150;display:flex;justify-content:center;padding:0 16px;}
.install-btn{background:linear-gradient(135deg,#16A34A,#15803D);color:#fff;border:none;border-radius:14px;padding:11px 24px;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 20px #16A34A44;display:flex;align-items:center;gap:8px;font-family:inherit;}
.gdrive-btn{background:linear-gradient(135deg,#4285F4,#34A853);color:#fff;border:none;border-radius:10px;padding:9px 14px;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:inherit;}
.gdrive-btn.connected{background:linear-gradient(135deg,#34A853,#15803D);}
.icon-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:10px;}
.icon-opt{font-size:22px;padding:6px;border-radius:8px;border:2px solid transparent;cursor:pointer;text-align:center;background:#F9FAFB;}
.icon-opt.sel{border-color:#16A34A;background:#DCFCE7;}
.color-grid{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;}
.color-opt{width:28px;height:28px;border-radius:50%;border:3px solid transparent;cursor:pointer;}
.color-opt.sel{border-color:#1C2B1A;}
.cat-del-btn{background:transparent;border:none;color:#EF4444;font-size:16px;cursor:pointer;padding:2px 6px;border-radius:6px;}
.sync-bar{background:#EFF6FF;border:1.5px solid #3B82F6;border-radius:14px;padding:11px 14px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.sync-bar.ok{background:#DCFCE7;border-color:#16A34A;}
.sync-bar.err{background:#FEF2F2;border-color:#EF4444;}
.sync-info{font-size:12px;flex:1;}
.sync-title{font-weight:700;font-size:13px;}
.backup-reminder{position:fixed;bottom:92px;left:50%;transform:translateX(-50%);background:#1e40af;color:#fff;border-radius:14px;padding:11px 18px;font-size:13px;font-weight:600;z-index:300;white-space:nowrap;box-shadow:0 4px 20px #00000044;display:flex;align-items:center;gap:10px;max-width:90vw;}
.backup-reminder button{background:#ffffff33;border:none;color:#fff;border-radius:8px;padding:4px 10px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;}
</style>
</head>
<body>
<div id="app"></div>
<script>
// в”Җв”Җ Google Drive config в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const GD_CLIENT_ID='187857159856-j7n6e72p2pnf4ep1jndsn137n9degrco.apps.googleusercontent.com';
const GD_SCOPE='https://www.googleapis.com/auth/drive.appdata';
const GD_FILE='grb_backup.json';
var gdToken=null; // access token when signed in

// в”Җв”Җ Categories (dynamic) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const DEFAULT_CATS=[
  {id:'kimikali',name:'бҠ¬бҲҡбҠ«бҲҚ',icon:'рҹ§Ә',color:'#7C3AED',bg:'#F5F3FF'},
  {id:'fengisayd',name:'бҚҲбҠ•бҢҠбҲібӢӯбӢө',icon:'рҹҚ„',color:'#BE185D',bg:'#FDF2F8'},
  {id:'madaberiya',name:'бҲӣбӢібү бҲӘбӢ«',icon:'рҹҢҫ',color:'#CA8A04',bg:'#FEF9C3'},
  {id:'arem',name:'бӢЁбҠ бҲЁбҲқ бҲӣбҢҘбҚҠбӢ«',icon:'рҹҢҝ',color:'#16A34A',bg:'#DCFCE7'},
  {id:'til',name:'бӢЁбүөбҲҚ бҲҳбӢөбҲғбҠ’бүө',icon:'рҹҗӣ',color:'#DC2626',bg:'#FEF2F2'},
  {id:'bereero',name:'бӢЁбү бҲЁбҲ®/бү°бүЈбӢӯ',icon:'рҹӘІ',color:'#EA580C',bg:'#FFF7ED'},
  {id:'zer',name:'бӢҳбҲ®бүҪ',icon:'рҹҢұ',color:'#059669',bg:'#ECFDF5'},
  {id:'messa',name:'бҲҳбҲібҲӘбӢ«/бҲҳбҲөбҠ–',icon:'рҹҡҝ',color:'#0284C7',bg:'#F0F9FF'},
  {id:'other',name:'бҲҢбҲҺбүҪ',icon:'рҹ“Ұ',color:'#6B7280',bg:'#F9FAFB'},
];
var CATS=loadCats();
function loadCats(){
  try{var r=localStorage.getItem('grb_cats');return r?JSON.parse(r):DEFAULT_CATS.slice();}catch(e){return DEFAULT_CATS.slice();}
}
function saveCats(){try{localStorage.setItem('grb_cats',JSON.stringify(CATS));}catch(e){}}
// Icon palette for custom categories
const CAT_ICONS=['рҹҢ»','рҹҢө','рҹҚҖ','рҹҢҙ','рҹҢІ','рҹҢі','рҹҚғ','рҹҢә','рҹҢё','рҹӘҙ','рҹҗқ','рҹҰӢ','рҹҗһ','рҹҗң','рҹҰ—','рҹҢЎпёҸ','рҹ’Ҡ','рҹ§ҙ','рҹӘЈ','рҹ”§','вҡҷпёҸ','рҹӣўпёҸ','рҹҢҠ','вҳҖпёҸ','рҹҢ§пёҸ','вқ„пёҸ','рҹ”¬','рҹ“Ұ','рҹҺҜ','рҹ’Ў'];
const CAT_COLORS=[
  {color:'#7C3AED',bg:'#F5F3FF'},{color:'#BE185D',bg:'#FDF2F8'},
  {color:'#CA8A04',bg:'#FEF9C3'},{color:'#16A34A',bg:'#DCFCE7'},
  {color:'#DC2626',bg:'#FEF2F2'},{color:'#EA580C',bg:'#FFF7ED'},
  {color:'#059669',bg:'#ECFDF5'},{color:'#0284C7',bg:'#F0F9FF'},
  {color:'#6B7280',bg:'#F9FAFB'},{color:'#0F766E',bg:'#F0FDFA'},
  {color:'#7E22CE',bg:'#FAF5FF'},{color:'#B45309',bg:'#FFFBEB'},
];

const SKEY=u=>'grb_'+u.replace(/\s/g,'_').toLowerCase();
function loadData(u){try{const r=localStorage.getItem(SKEY(u));return r?JSON.parse(r):null;}catch(e){return null;}}
function saveData(u,p,s,t){try{localStorage.setItem(SKEY(u),JSON.stringify({products:p,sales:s,trash:t||[]}));}catch(e){}}
const DEMO={
  products:[
    {id:'p1',name:'бҲ«бӢҚбҠ•бӢө бҠ бҚ•',category:'arem',quantity:50,buyPrice:380,sellPrice:550,unit:'бҲҠ',expDate:'2027-03-01',desc:'бҠЁбҲҳбҢ бүҖбҲқбӢҺ бү бҚҠбүө бҲҳбҲҳбҲӘбӢ«бӢҚбҠ• бӢ«бҠ•бүҘбүЎбҚў бҠЁбҲқбҢҚбүҘ бҲқбҲӯбү¶бүҪ бҲӯбүҶ бӢӯбүҖбҲҳбҢҘбҚў бҲҚбҢҶбүҪ бҠҘбҢ… бҠҘбҠ•бӢібӢӯбӢ°бҲӯбҲөбҚў'},
    {id:'p2',name:'бҢҚбҲ«бҲһбҠӯбҲ¶бҠ•',category:'arem',quantity:30,buyPrice:420,sellPrice:600,unit:'бҲҠ',expDate:'2026-08-15'},
    {id:'p3',name:'бҠ®бҠ•бҚҠбӢ¶бҲӯ',category:'kimikali',quantity:40,buyPrice:250,sellPrice:380,unit:'бҲҠ',expDate:'2026-06-10'},
    {id:'p4',name:'бӢібӢӯбҲңбү¶бҠӨбүө',category:'til',quantity:25,buyPrice:300,sellPrice:450,unit:'бҲҠ',expDate:'2026-12-01'},
    {id:'p5',name:'бҲібӢӯбҚҗбҲӯбҲңбүөбҲӘбҠ•',category:'bereero',quantity:35,buyPrice:200,sellPrice:320,unit:'бҲҠ',expDate:'2027-01-20'},
    {id:'p6',name:'бӢ©бҲӘбӢ« бҲӣбӢібү бҲӘбӢ«',category:'madaberiya',quantity:120,buyPrice:1800,sellPrice:2200,unit:'бҠЁбҲЁбҢўбүө',expDate:''},
    {id:'p7',name:'DAP бҲӣбӢібү бҲӘбӢ«',category:'madaberiya',quantity:80,buyPrice:2200,sellPrice:2700,unit:'бҠЁбҲЁбҢўбүө',expDate:''},
    {id:'p8',name:'бӢЁбү бүҶбҲҺ бӢҳбҲӯ BH-540',category:'zer',quantity:60,buyPrice:450,sellPrice:650,unit:'бҠӘ.бҢҚ',expDate:'2026-09-01'},
    {id:'p9',name:'бӢЁбҲөбҠ•бӢҙ бӢҳбҲӯ',category:'zer',quantity:90,buyPrice:280,sellPrice:420,unit:'бҠӘ.бҢҚ',expDate:'2026-07-01'},
    {id:'p10',name:'бӢөбҲӘбҚ• бүұбүҰ',category:'messa',quantity:10,buyPrice:3500,sellPrice:5000,unit:'бҢҘбү…бҲҚ',expDate:''},
  ],
  sales:[
    {id:'s1',productId:'p6',productName:'бӢ©бҲӘбӢ« бҲӣбӢібү бҲӘбӢ«',qty:5,price:2200,total:11000,date:'2026-05-06'},
    {id:'s2',productId:'p1',productName:'бҲ«бӢҚбҠ•бӢө бҠ бҚ•',qty:8,price:550,total:4400,date:'2026-05-07'},
    {id:'s3',productId:'p8',productName:'бӢЁбү бүҶбҲҺ бӢҳбҲӯ BH-540',qty:10,price:650,total:6500,date:'2026-05-08'},
  ]
};
const ETB=n=>Number(n||0).toLocaleString()+' бүҘбҲӯ';
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2,6);
const today=()=>new Date().toISOString().slice(0,10);
const getCat=id=>CATS.find(c=>c.id===id)||CATS[CATS.length-1];

// Exp date helpers
function expStatus(expDate){
  if(!expDate) return null;
  const now=new Date(); const exp=new Date(expDate);
  const diffDays=Math.ceil((exp-now)/(1000*60*60*24));
  if(diffDays<0) return {status:'expired',label:'бҢҠбӢң бҠ бҲҚбҚҺбү бүібҲҚ!',days:diffDays};
  if(diffDays<=30) return {status:'soon',label:diffDays+' бүҖбҠ• бӢӯбүҖбҲЁбӢӢбҲҚ',days:diffDays};
  return {status:'ok',label:diffDays+' бүҖбҠ• бӢӯбүҖбҲЁбӢӢбҲҚ',days:diffDays};
}

let S={
  user:null,products:[],sales:[],trash:[],tab:'dash',
  selCat:null,
  showPForm:false,editP:null,
  pF:{name:'',category:'arem',quantity:'',buyPrice:'',sellPrice:'',unit:'бҲҠ',expDate:'',desc:''},
  showSForm:false,editS:null,
  sF:{productId:'',qty:'',date:today()},
  confDel:null,confDelSale:null,
  pSearch:'',sSearch:'',
  detailP:null,
  showCatForm:false,
  catF:{name:'',icon:'рҹҢ»',colorIdx:0},
  loginVal:'',loginErr:'',
  // PIN auth
  loginStep:'id', // 'id' | 'pin-set' | 'pin-enter'
  pinVal:'',pinConfirm:'',pinErr:'',
  pendingUser:'',
  toast:null,toastTimer:null,
  // Google Drive
  gdSyncing:false,gdLastSync:null,gdError:null,
  backupReminder:false,
};

// в”Җв”Җ PIN helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function pinKey(u){return 'grb_pin_'+u.replace(/\s/g,'_').toLowerCase();}
function getPin(u){return localStorage.getItem(pinKey(u));}
function setPin(u,pin){localStorage.setItem(pinKey(u),pin);}
function hashPin(pin){// simple hash for basic security
  var h=0;for(var i=0;i<pin.length;i++){h=((h<<5)-h)+pin.charCodeAt(i);h|=0;}return h.toString(36);
}

// в”Җв”Җ Google Drive Sync в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function gdSignIn(){
  if(!window.google){showToast('вҡ пёҸ Google бҢҲбҠ“ бҠ бҲҚбү°бҢ«бҠҗбҲқбҚЈ бӢӯбҲһбҠӯбҲ©');return;}
  var client=google.accounts.oauth2.initTokenClient({
    client_id:GD_CLIENT_ID,
    scope:GD_SCOPE,
    callback:function(resp){
      if(resp.error){set({gdError:'Google бҢҚбүЈ бҠ бҲҚбү°бҲібҠ«бҲқ'});showToast('вқҢ Google бҢҚбүЈ бҠ бҲҚбү°бҲібҠ«бҲқ');return;}
      gdToken=resp.access_token;
      localStorage.setItem('grb_gd_token_hint','1');
      showToast('вң… Google Drive бү°бҢҲбҠ“бҠҳ!');
      gdSyncUp();
    }
  });
  client.requestAccessToken();
}
function gdSignOut(){
  gdToken=null;
  localStorage.removeItem('grb_gd_token_hint');
  set({gdLastSync:null,gdError:null});
  showToast('Google Drive бү°бүӢбҲӯбҢ§бҲҚ');
}
async function gdSyncUp(){
  if(!gdToken||!S.user){return;}
  set({gdSyncing:true,gdError:null});
  try{
    var data=JSON.stringify({products:S.products,sales:S.sales,trash:S.trash,user:S.user,savedAt:new Date().toISOString()});
    // find existing file
    var listR=await fetch('https://www.googleapis.com/drive/v3/files?spaces=appDataFolder&q=name%3D%22'+GD_FILE+'%22&fields=files(id)',
      {headers:{Authorization:'Bearer '+gdToken}});
    var listJ=await listR.json();
    var fileId=listJ.files&&listJ.files[0]?listJ.files[0].id:null;
    if(fileId){
      // update
      await fetch('https://www.googleapis.com/upload/drive/v3/files/'+fileId+'?uploadType=media',
        {method:'PATCH',headers:{Authorization:'Bearer '+gdToken,'Content-Type':'application/json'},body:data});
    } else {
      // create
      var meta=JSON.stringify({name:GD_FILE,parents:['appDataFolder']});
      var boundary='grb_bound';
      var body='--'+boundary+'\r\nContent-Type: application/json\r\n\r\n'+meta+'\r\n--'+boundary+'\r\nContent-Type: application/json\r\n\r\n'+data+'\r\n--'+boundary+'--';
      await fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart',
        {method:'POST',headers:{Authorization:'Bearer '+gdToken,'Content-Type':'multipart/related; boundary='+boundary},body:body});
    }
    var now=new Date().toLocaleTimeString('am-ET');
    set({gdSyncing:false,gdLastSync:now,gdError:null});
    localStorage.setItem('grb_last_sync',now);
  }catch(e){
    set({gdSyncing:false,gdError:'Sync бҠ бҲҚбү°бҲібҠ«бҲқ'});
  }
}
async function gdSyncDown(){
  if(!gdToken){showToast('вҡ пёҸ Google Drive бӢ«бҢҲбҠ“бҠҷ');return;}
  set({gdSyncing:true,gdError:null});
  try{
    var listR=await fetch('https://www.googleapis.com/drive/v3/files?spaces=appDataFolder&q=name%3D%22'+GD_FILE+'%22&fields=files(id)',
      {headers:{Authorization:'Bearer '+gdToken}});
    var listJ=await listR.json();
    var fileId=listJ.files&&listJ.files[0]?listJ.files[0].id:null;
    if(!fileId){set({gdSyncing:false});showToast('вҳҒпёҸ Cloud бҲӢбӢӯ бҲқбҠ•бҲқ backup бӢЁбҲҲбҲқ');return;}
    var fileR=await fetch('https://www.googleapis.com/drive/v3/files/'+fileId+'?alt=media',
      {headers:{Authorization:'Bearer '+gdToken}});
    var d=await fileR.json();
    if(!d.products){set({gdSyncing:false,gdError:'бҚӢбӢӯбҲү бҲҠбҠҗбү бүҘ бҠ бҲҚбү»бҲҲ'});return;}
    var ps=d.products||[];var ss=d.sales||[];var tr=d.trash||[];
    saveData(S.user,ps,ss,tr);
    set({products:ps,sales:ss,trash:tr,gdSyncing:false,gdLastSync:'Cloud',gdError:null});
    showToast('вң… Cloud backup бү°бҢ«бҠҗ! ('+ps.length+' бӢ•бүғ)');
  }catch(e){
    set({gdSyncing:false,gdError:'Download бҠ бҲҚбү°бҲібҠ«бҲқ'});
  }
}

// Auto-sync on every save
var _origSaveData=saveData;
function saveData(u,p,s,t){
  _origSaveData(u,p,s,t);
  if(gdToken) setTimeout(function(){gdSyncUp();},800);
  // backup reminder: if no GDrive and no sync for 7 days
  checkBackupReminder();
}
function checkBackupReminder(){
  if(gdToken) return;
  var lastRemind=localStorage.getItem('grb_remind');
  var now=Date.now();
  if(!lastRemind||now-parseInt(lastRemind)>7*24*60*60*1000){
    set({backupReminder:true});
  }
}
function dismissReminder(){
  localStorage.setItem('grb_remind',Date.now().toString());
  set({backupReminder:false});
}

function set(patch){
  Object.assign(S,patch);
  if(patch.user!==undefined){patch.user?localStorage.setItem('grb_session',patch.user):localStorage.removeItem('grb_session');}
  render();
}
function showToast(msg){if(S.toastTimer)clearTimeout(S.toastTimer);const t=setTimeout(()=>set({toast:null,toastTimer:null}),2500);set({toast:msg,toastTimer:t});}

// в”Җв”Җ Category CRUD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function saveCat(){
  var f=S.catF;
  if(!f.name.trim()){showToast('вҡ пёҸ бӢЁбҲқбӢөбүЎ бҲөбҲқ бӢ«бҲөбҚҲбҲҚбҢӢбҲҚ');return;}
  var col=CAT_COLORS[f.colorIdx]||CAT_COLORS[0];
  var newCat={id:'cat_'+uid(),name:f.name.trim(),icon:f.icon,color:col.color,bg:col.bg};
  // insert before "бҲҢбҲҺбүҪ" (last)
  var last=CATS[CATS.length-1];
  CATS.splice(CATS.length-1,0,newCat);
  saveCats();
  set({showCatForm:false,catF:{name:'',icon:'рҹҢ»',colorIdx:0}});
  showToast('вң… бҲқбӢөбүҘ бү°бҢЁбҲқбҲҜбҲҚ: '+newCat.name);
}
function delCat(id){
  var idx=CATS.findIndex(function(c){return c.id===id;});
  if(idx<0) return;
  // move products in this cat to 'other'
  var ps=S.products.map(function(p){return p.category===id?{...p,category:'other'}:p;});
  CATS.splice(idx,1);
  saveCats();
  saveData(S.user,ps,S.sales,S.trash);
  set({products:ps});
  showToast('рҹ—‘пёҸ бҲқбӢөбүҘ бү°бҲ°бҲӯбӢҹбҲҚ');
}

// в”Җв”Җ Actions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function login(){
  var v=S.loginVal.trim();
  if(!v){set({loginErr:'бҲөбҲҚбҠӯ бүҒбҢҘбҲӯ бӢҲбӢӯбҲқ Email бҠ бҲөбҢҲбүЎ'});return;}
  var ok=/^[0-9+]{7,15}$/.test(v.replace(/\s/g,''))||/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
  if(!ok){set({loginErr:'бүөбҠӯбҠӯбҲҲбҠӣ бҲөбҲҚбҠӯ бүҒбҢҘбҲӯ бӢҲбӢӯбҲқ Email бҠ бҲөбҢҲбүЎ'});return;}
  var existingPin=getPin(v);
  if(existingPin){
    // user exists вҖ” ask for PIN
    set({loginStep:'pin-enter',pendingUser:v,pinVal:'',pinErr:''});
  } else {
    // new user вҖ” set PIN
    set({loginStep:'pin-set',pendingUser:v,pinVal:'',pinConfirm:'',pinErr:''});
  }
}
function loginSetPin(){
  var pin=S.pinVal.trim();
  var confirm=S.pinConfirm.trim();
  if(pin.length<4){set({pinErr:'PIN бүўбӢ«бҠ•бҲө 4 бҠ бҲғбӢқ бҲҳбҲҶбҠ• бҠ бҲҲбү бүө'});return;}
  if(!/^\d+$/.test(pin)){set({pinErr:'PIN бүҒбҢҘбҲ®бүҪ бүҘбү» бҲҳбҲҶбҠ• бҠ бҲҲбү бүө'});return;}
  if(pin!==confirm){set({pinErr:'PIN бүҒбҢҘбҲ®бү№ бҠ бӢӯбӢӣбҲҳбӢұбҲқ'});return;}
  setPin(S.pendingUser,hashPin(pin));
  doLogin(S.pendingUser);
}
function loginEnterPin(){
  var pin=S.pinVal.trim();
  if(!pin){set({pinErr:'PIN бӢ«бҲөбҢҲбүЎ'});return;}
  var stored=getPin(S.pendingUser);
  if(hashPin(pin)!==stored){set({pinErr:'вқҢ PIN бүөбҠӯбҠӯбҲҚ бҠ бӢӯбӢ°бҲҲбҲқ',pinVal:''});return;}
  doLogin(S.pendingUser);
}
function doLogin(u){
  var d=loadData(u);
  set({user:u,products:d?d.products:DEMO.products,sales:d?d.sales:DEMO.sales,trash:d?d.trash||[]:[], loginStep:'id',pendingUser:'',pinVal:'',pinConfirm:'',pinErr:'',loginVal:'',loginErr:''});
  checkExpNotifications(d?d.products:DEMO.products);
  setTimeout(checkBackupReminder,3000);
}
function logout(){set({user:null,products:[],sales:[],trash:[],tab:'dash',selCat:null,loginVal:'',loginErr:'',loginStep:'id',pendingUser:'',pinVal:'',pinConfirm:'',pinErr:''});}

function checkExpNotifications(prods){
  if(!('Notification' in window)) return;
  const expiring=prods.filter(p=>{const s=expStatus(p.expDate);return s&&(s.status==='expired'||s.status==='soon');});
  if(expiring.length===0) return;
  if(Notification.permission==='granted'){
    expiring.forEach(p=>{
      const s=expStatus(p.expDate);
      new Notification('рҹҢұ бҢҚбүҘбҲӯбҠ“ бҲұбү… вҖ” '+p.name,{body:s.label,icon:''});
    });
  } else if(Notification.permission!=='denied'){
    Notification.requestPermission().then(perm=>{
      if(perm==='granted') expiring.forEach(p=>{const s=expStatus(p.expDate);new Notification('рҹҢұ '+p.name,{body:s.label});});
    });
  }
}

function saveProd(){
  const f=S.pF;
  if(!f.name||!f.quantity||!f.sellPrice){showToast('вҡ пёҸ бҲөбҲқбҚЈ бүҘбӢӣбүөбҚЈ бӢӢбҢӢ бӢ«бҲөбҚҲбҲҚбҢӢбҲҚ');return;}
  let ps;
  if(S.editP) ps=S.products.map(p=>p.id===S.editP.id?{...p,...f,quantity:+f.quantity,buyPrice:+f.buyPrice,sellPrice:+f.sellPrice,desc:f.desc||''}:p);
  else ps=[...S.products,{id:uid(),...f,quantity:+f.quantity,buyPrice:+f.buyPrice,sellPrice:+f.sellPrice,desc:f.desc||''}];
  saveData(S.user,ps,S.sales,S.trash);
  set({products:ps,showPForm:false,editP:null});
  showToast('вң… бӢ•бүғ бү°бүҖбҲқбҢ§бҲҚ');
}
function delProd(id){
  const p=S.products.find(x=>x.id===id);
  if(!p) return;
  const ps=S.products.filter(x=>x.id!==id);
  const tr=[...S.trash,{...p,deletedAt:today()}];
  saveData(S.user,ps,S.sales,tr);
  set({products:ps,trash:tr,confDel:null});
  showToast('рҹ—‘пёҸ бӢҲбӢ° бүібҲӘбҠӯ бү°бӢҲбҲ°бӢ°');
}
function restoreProd(id){
  const p=S.trash.find(x=>x.id===id);
  if(!p) return;
  const {deletedAt,...prod}=p;
  const tr=S.trash.filter(x=>x.id!==id);
  const ps=[...S.products,prod];
  saveData(S.user,ps,S.sales,tr);
  set({products:ps,trash:tr});
  showToast('вң… бӢ•бүғ бү°бҲҳбҲҚбҲ·бҲҚ!');
}
function permDel(id){
  const tr=S.trash.filter(x=>x.id!==id);
  saveData(S.user,S.products,S.sales,tr);
  set({trash:tr});
  showToast('рҹ—‘пёҸ бҲҷбҲү бү°бҲ°бҲӯбӢҹбҲҚ');
}

// в”Җв”Җ Sale CRUD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function saveSale(){
  const f=S.sF;
  const prod=S.products.find(p=>p.id===f.productId);
  if(!prod||!f.qty||+f.qty<=0){showToast('вҡ пёҸ бӢ•бүғ бҠҘбҠ“ бүҘбӢӣбүө бҲқбҲЁбҢЎ');return;}
  let ss,ps;
  if(S.editS){
    // editing existing sale вҖ” restore old qty first
    const old=S.sales.find(s=>s.id===S.editS);
    const oldProd=S.products.find(p=>p.id===old.productId);
    // restore old qty
    ps=S.products.map(p=>{
      if(p.id===old.productId) return {...p,quantity:p.quantity+old.qty};
      return p;
    });
    // check new qty
    const newProd=ps.find(p=>p.id===f.productId);
    if(+f.qty>newProd.quantity){showToast('вҡ пёҸ бӢ«бҲҲбӢҚ бҠӯбҲқбүҪбүө: '+newProd.quantity+' '+newProd.unit);return;}
    const total=+f.qty*newProd.sellPrice;
    ss=S.sales.map(s=>s.id===S.editS?{...s,productId:newProd.id,productName:newProd.name,qty:+f.qty,price:newProd.sellPrice,total,date:f.date}:s);
    ps=ps.map(p=>p.id===f.productId?{...p,quantity:p.quantity-+f.qty}:p);
  } else {
    if(+f.qty>prod.quantity){showToast('вҡ пёҸ бӢ«бҲҲбӢҚ бҠӯбҲқбүҪбүө: '+prod.quantity+' '+prod.unit);return;}
    const total=+f.qty*prod.sellPrice;
    ss=[...S.sales,{id:uid(),productId:prod.id,productName:prod.name,qty:+f.qty,price:prod.sellPrice,total,date:f.date}];
    ps=S.products.map(p=>p.id===prod.id?{...p,quantity:p.quantity-+f.qty}:p);
  }
  saveData(S.user,ps,ss,S.trash);
  set({sales:ss,products:ps,showSForm:false,editS:null,sF:{productId:'',qty:'',date:today()}});
  showToast('вң… бҲҪбӢ«бҢӯ бү°бүҖбҲқбҢ§бҲҚ');
}
function delSale(id){
  const s=S.sales.find(x=>x.id===id);
  if(!s) return;
  // restore qty
  const ps=S.products.map(p=>p.id===s.productId?{...p,quantity:p.quantity+s.qty}:p);
  const ss=S.sales.filter(x=>x.id!==id);
  saveData(S.user,ps,ss,S.trash);
  set({sales:ss,products:ps,confDelSale:null});
  showToast('рҹ—‘пёҸ бҲҪбӢ«бҢӯ бү°бҲ°бҲӯбӢҹбҲҚ вҖ” бҠӯбҲқбүҪбүө бү°бҲҳбҲҚбҲ·бҲҚ');
}

// в”Җв”Җ Export в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function exportJSON(){
  var d={products:S.products,sales:S.sales,trash:S.trash,exportedAt:new Date().toISOString(),user:S.user};
  var blob=new Blob([JSON.stringify(d,null,2)],{type:'application/json'});
  var a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='бҢҚбүҘбҲӯбҠ“-бҲұбү…-'+today()+'.json';
  a.click();
  showToast('вң… JSON бү°бӢҲбҲӯбӢ·бҲҚ');
}
function exportCSV(){
  var rows=[['бҲөбҲқ','бҲқбӢөбүҘ','бүҘбӢӣбүө','бӢЁбҢҚбӢҘ бӢӢбҢӢ','бӢЁбҲҪбӢ«бҢӯ бӢӢбҢӢ','бҲҳбҲҲбҠӘбӢ«','бҢҠбӢң бҲӣбҲҲбүӮбӢ«','бҲӣбүҘбҲ«бҲӘбӢ«']];
  S.products.forEach(function(p){
    var cat=getCat(p.category);
    rows.push([p.name,cat.name,p.quantity,p.buyPrice,p.sellPrice,p.unit,p.expDate||'',p.desc||'']);
  });
  rows.push([]);
  rows.push(['бүҖбҠ•','бҲқбҲӯбүө','бүҘбӢӣбүө','бӢӢбҢӢ','бҢ бү…бҲӢбҲӢ']);
  S.sales.forEach(function(s){
    rows.push([s.date,s.productName,s.qty,s.price,s.total]);
  });
  var csv=rows.map(function(r){return r.map(function(c){return '"'+(c+'').replace(/"/g,'""')+'"';}).join(',');}).join('\n');
  var blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  var a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='бҢҚбүҘбҲӯбҠ“-бҲұбү…-'+today()+'.csv';
  a.click();
  showToast('вң… CSV бү°бӢҲбҲӯбӢ·бҲҚ');
}
function importJSON(file){
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var d=JSON.parse(e.target.result);
      if(!d.products||!d.sales){showToast('вҡ пёҸ бҚӢбӢӯбҲү бүөбҠӯбҠӯбҲҚ бҠ бӢӯбӢ°бҲҲбҲқ');return;}
      var ps=d.products||[];var ss=d.sales||[];var tr=d.trash||[];
      saveData(S.user,ps,ss,tr);
      set({products:ps,sales:ss,trash:tr});
      showToast('вң… бӢҚбҲӮбүҘ бү°бҢӯбҠ—бҲҚ! ('+ps.length+' бӢ•бүғ)');
    }catch(err){showToast('вҡ пёҸ бҚӢбӢӯбҲүбҠ• бҲӣбҠ•бү бүҘ бҠ бҲҚбү°бү»бҲҲбҲқ');}
  };
  reader.readAsText(file);
}

// в”Җв”Җ Derived в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function D(){
  const p=S.products,s=S.sales;
  const inv=p.reduce((a,x)=>a+x.quantity*x.buyPrice,0);
  const rev=s.reduce((a,x)=>a+x.total,0);
  const prof=s.reduce((a,x)=>{const pr=p.find(r=>r.id===x.productId);return a+(pr?(x.price-pr.buyPrice)*x.qty:0);},0);
  const low=p.filter(x=>x.quantity<=10);
  const expAlert=p.filter(x=>{const es=expStatus(x.expDate);return es&&(es.status==='expired'||es.status==='soon');});
  return{inv,rev,prof,low,expAlert};
}

// в”Җв”Җ Render в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function render(){
  const app=document.getElementById('app');
  if(!S.user){app.innerHTML=rLogin();bindLogin();return;}
  const d=D();
  var html=rHdr(d)+
    '<div class="main">'+
    (S.tab==='dash'?rDash(d):'')+
    (S.tab==='inv'?rInv():'')+
    (S.tab==='sales'?rSales():'')+
    (S.tab==='report'?rReport(d):'')+
    (S.tab==='trash'?rTrash():'')+
    '</div>'+
    rInstallBar()+
    rBnav()+
    (S.showPForm?rPMod():'')+
    (S.showSForm?rSMod():'')+
    (S.showCatForm?rCatForm():'')+
    (S.detailP?rDetailMod():'')+
    (S.confDel?rConfDel():'')+
    (S.confDelSale?rConfDelSale():'')+
    (S.backupReminder&&!gdToken?'<div class="backup-reminder">рҹ’ҫ бӢҚбҲӮбүҘ backup бҠ бҲҚбү°бӢ°бҲЁбҢҲбҲқ <button id="rem-drive">Google Drive</button><button id="rem-dismiss">вң•</button></div>':'')+
    (S.toast?'<div class="toast">'+S.toast+'</div>':'');
  app.innerHTML=html;
  bindMain();
}

function rLogin(){
  if(S.loginStep==='pin-set'){
    return '<div class="lbg"><div class="lcard">'+
      '<div class="llogo"><div class="em">рҹ”җ</div><h2>PIN бӢ«бүҖбҠ“бүҘбҲ©</h2><p>'+S.pendingUser+'</p></div>'+
      '<div class="ibox">рҹ”’ PIN бүҒбҢҘбҲӯ бҲҲбӢ°бҲ…бҠ•бҠҗбүө бӢ«бҲөбҚҲбҲҚбҢӢбҲҚбҚў бҲҢбҲҺбүҪ бҲ°бӢҺбүҪ бӢҚбҲӮбүҘбӢҺбҠ• бҲӣбӢЁбүө бҠ бӢӯбүҪбҲүбҲқбҚў</div>'+
      '<div class="lbl">бҠ бӢІбҲө PIN (бүўбӢ«бҠ•бҲө 4 бҠ бҲғбӢқ)</div>'+
      '<input id="pin1" class="inp" type="password" inputmode="numeric" placeholder="вҖўвҖўвҖўвҖў" maxlength="8" value="'+S.pinVal+'" style="font-size:22px;letter-spacing:6px;text-align:center;padding:12px"/>'+
      '<div class="lbl">PIN бӢөбҢӢбҲҡ бӢ«бҲөбҢҲбүЎ</div>'+
      '<input id="pin2" class="inp" type="password" inputmode="numeric" placeholder="вҖўвҖўвҖўвҖў" maxlength="8" value="'+S.pinConfirm+'" style="font-size:22px;letter-spacing:6px;text-align:center;padding:12px"/>'+
      (S.pinErr?'<div class="err">'+S.pinErr+'</div>':'')+
      '<button id="pin-set-btn" class="btn p full" style="margin-top:4px">рҹ”җ PIN бӢ«бҲөбүҖбҲқбҢЎ</button>'+
      '<button id="pin-back" class="btn g full" style="margin-top:8px">вҶҗ бү°бҲҳбҲҲбҲө</button>'+
      '</div></div>';
  }
  if(S.loginStep==='pin-enter'){
    return '<div class="lbg"><div class="lcard">'+
      '<div class="llogo"><div class="em">рҹ”‘</div><h2>PIN бӢ«бҲөбҢҲбүЎ</h2><p>'+S.pendingUser+'</p></div>'+
      '<div class="lbl">PIN бүҒбҢҘбҲӯ</div>'+
      '<input id="pin-e" class="inp" type="password" inputmode="numeric" placeholder="вҖўвҖўвҖўвҖў" maxlength="8" value="'+S.pinVal+'" style="font-size:22px;letter-spacing:6px;text-align:center;padding:12px"/>'+
      (S.pinErr?'<div class="err">'+S.pinErr+'</div>':'')+
      '<button id="pin-enter-btn" class="btn p full" style="margin-top:4px">рҹ”“ бҢҚбүЈ</button>'+
      '<button id="pin-back" class="btn g full" style="margin-top:8px">вҶҗ бү°бҲҳбҲҲбҲө</button>'+
      '</div></div>';
  }
  return '<div class="lbg"><div class="lcard">'+
    '<div class="llogo"><div class="em">рҹҢұ</div><h2>бҢҚбүҘбҲӯбҠ“ бҲұбү…</h2><p>бӢЁбҢҚбүҘбҲӯбҠ“ бҢҚбүҘбҠ бүө бҠҘбҠ“ бҠ¬бҲҡбҠ«бҲҚ</p></div>'+
    '<div class="lbl">бҲөбҲҚбҠӯ бүҒбҢҘбҲӯ бӢҲбӢӯбҲқ Email</div>'+
    '<input id="li" class="inp" placeholder="09xxxxxxxx бӢҲбӢӯбҲқ name@email.com" value="'+S.loginVal+'" style="font-size:15px;padding:12px 14px;"/>'+
    (S.loginErr?'<div class="err">вҡ пёҸ '+S.loginErr+'</div>':'')+
    '<div class="ibox">рҹ”’ бӢҚбҲӮбүҘбӢҺ бҲөбҲҚбҠӯ бҲӢбӢӯ бӢӯбүҖбҲҳбҢЈбҲҚбҚў PIN бӢ°бҲ…бҠ•бҠҗбүө бҠ бҲҲбҚў бӢ«бҲҲ бҠўбҠ•бү°бҲӯбҠ”бүө бӢӯбҲ°бҲ«бҲҚбҚў</div>'+
    '<button id="lb" class="btn p full">бҢҚбүЈ / бҲқбӢқбҢҲбүЈ вҶ’</button>'+
    '</div></div>';
}

function rHdr(d){
  var expCount=d?d.expAlert.length:0;
  var syncIcon=gdToken?(S.gdSyncing?'рҹ”„':'вҳҒпёҸвң…'):'';
  return '<div class="hdr"><div class="hdr-in">'+
    '<div><h1>рҹҢұ бҢҚбүҘбҲӯбҠ“ бҲұбү…'+(expCount>0?' <span style="background:#EF4444;color:#fff;border-radius:8px;padding:1px 7px;font-size:11px;vertical-align:middle">вҡ пёҸ'+expCount+'</span>':'')+'</h1>'+
    '<div class="sub">'+S.user+(syncIcon?' В· '+syncIcon+(S.gdLastSync?' '+S.gdLastSync:''):'')+'</div></div>'+
    '<button class="out-btn" id="ob">бӢҚбҢЈ</button>'+
    '</div></div>';
}

function rInstallBar(){
  return '<div class="install-bar" id="install-bar" style="display:none">'+
    '<button class="install-btn" id="install-btn">рҹ“І бҲөбҲҚбҠӯ бҲӢбӢӯ Install бҠ бӢөбҲӯбҢҚ</button>'+
    '</div>';
}
function rBnav(){
  var tabs=[{k:'dash',i:'рҹҸ ',l:'бӢӢбҠ“'},{k:'inv',i:'рҹҢҝ',l:'бӢ•бүғ'},{k:'sales',i:'рҹ’°',l:'бҲҪбӢ«бҢӯ'},{k:'report',i:'рҹ“Ҡ',l:'бҲӘбҚ–бҲӯбүө'},{k:'trash',i:'рҹ—‘пёҸ',l:'бүібҲӘбҠӯ'}];
  return '<div class="bnav"><div class="bnav-in">'+
    tabs.map(t=>'<button class="nb'+(S.tab===t.k?' active':'')+'" data-tab="'+t.k+'"><span class="ni">'+t.i+'</span><span>'+t.l+'</span></button>').join('')+
    '</div></div>';
}

function rDash(d){
  var html='<div class="g2">';
  html+='<div class="card grn"><div style="font-size:20px;margin-bottom:5px">рҹ“Ұ</div><div class="sv g">'+S.products.reduce(function(s,p){return s+p.quantity;},0)+' бүҒ</div><div class="sl">бҢ бү…бҲӢбҲӢ бӢ•бүғ</div></div>';
  html+='<div class="card gold"><div style="font-size:20px;margin-bottom:5px">рҹҸ·пёҸ</div><div class="sv go">'+ETB(d.inv)+'</div><div class="sl">бӢЁбӢ•бүғ бӢӢбҢӢ</div></div>';
  html+='<div class="card grn"><div style="font-size:20px;margin-bottom:5px">рҹ’°</div><div class="sv g">'+ETB(d.rev)+'</div><div class="sl">бҢ бү…бҲӢбҲӢ бҲҪбӢ«бҢӯ</div></div>';
  html+='<div class="card grn"><div style="font-size:20px;margin-bottom:5px">рҹ“Ҳ</div><div class="sv a">'+ETB(d.prof)+'</div><div class="sl">бүөбҲӯбҚҚ</div></div>';
  html+='</div>';
  // Exp alert
  if(d.expAlert.length>0){
    html+='<div class="exp-banner"><div class="etitle">вҡ пёҸ бҢҠбӢң бҠҘбӢ«бҲҲбүҖ бӢ«бҲү бӢ•бүғбӢҺбүҪ ('+d.expAlert.length+')</div>';
    d.expAlert.forEach(function(p){
      var es=expStatus(p.expDate);
      html+='<div class="exp-row"><span>'+p.name+'</span><span class="badge '+(es.status==='expired'?'exp':'soon')+'">'+es.label+'</span></div>';
    });
    html+='</div>';
  }
  if(d.low.length>0){
    html+='<div class="card warn"><div class="st" style="color:#EF4444">вҡ пёҸ бӢқбү…бү°бҠӣ бҠӯбҲқбүҪбүө ('+d.low.length+')</div>';
    d.low.forEach(function(p){html+='<div class="wr"><span>'+p.name+'</span><span class="wv">'+p.quantity+' '+p.unit+'</span></div>';});
    html+='</div>';
  }
  html+='<div class="card"><div class="st">рҹ•’ бӢЁбү…бҲӯбүҘ бҲҪбӢ«бҢ®бүҪ</div>';
  if(S.sales.length===0) html+='<div class="empty">бҲҪбӢ«бҢӯ бҢҲбҠ“ бҠ бҲҚбү°бҲҳбӢҳбҢҲбү бҲқ</div>';
  else S.sales.slice(-5).reverse().forEach(function(s){
    html+='<div class="row"><div><div class="rn">'+s.productName+'</div><div class="rs">'+s.date+' В· '+s.qty+' бүҒ</div></div><div class="rv">'+ETB(s.total)+'</div></div>';
  });
  html+='</div>';
  return html;
}

function rInv(){
  if(!S.selCat) return rCatGrid();
  var cat=getCat(S.selCat);
  var catProds=S.products.filter(function(p){return p.category===S.selCat;});
  var filtered=catProds.filter(function(p){return p.name.includes(S.pSearch);});
  var html='<div class="fr">'+
    '<button class="back-btn" id="back-cat">вҶҗ бү°бҲҳбҲҲбҲө</button>'+
    '<button class="btn p" id="ap-btn" style="font-size:12px;padding:8px 12px">+ бҠ бӢІбҲө бӢ•бүғ</button>'+
    '</div>';
  html+='<div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;background:'+cat.bg+';border:1.5px solid '+cat.color+'33;border-radius:12px;padding:10px 14px;">';
  html+='<span style="font-size:26px">'+cat.icon+'</span><div><div style="font-weight:800;font-size:14px;color:'+cat.color+'">'+cat.name+'</div><div style="font-size:11px;color:#6B7280">'+catProds.length+' бӢ•бүғ</div></div></div>';
  html+='<input class="inp" id="ps" placeholder="бӢ•бүғ бҚҲбҲҚбҢҚ..." value="'+S.pSearch+'" style="margin-bottom:10px"/>';
  if(filtered.length===0){html+='<div class="empty">бӢ•бүғ бҠ бҲҚбү°бҢҲбҠҳбҲқ вҖ” + бҠ бӢІбҲө бӢ•бүғ бҢЁбҲқбҲӯ</div>';}
  else {
    html+='<div class="prod-grid">';
    filtered.slice().sort(function(a,b){return a.name.localeCompare(b.name,'am');}).forEach(function(p){
      var es=expStatus(p.expDate);
      var cls='pg-card'+(es&&es.status==='expired'?' expired':es&&es.status==='soon'?' exp-soon':'');
      html+='<div class="'+cls+'" data-detail="'+p.id+'" style="cursor:pointer">';
      html+='<div class="pg-badge">'+cat.icon+' '+cat.name+'</div>';
      html+='<div class="pg-name">'+p.name+'</div>';
      html+='<div class="pg-price">'+ETB(p.sellPrice)+'</div>';
      html+='<div class="pg-unit">/ '+p.unit+'</div>';
      if(es) html+='<div class="pg-exp '+es.status+'">рҹ“… '+es.label+'</div>';
      else if(p.expDate) html+='<div class="pg-exp ok">рҹ“… '+p.expDate+'</div>';
      html+='<div class="pg-qty'+(p.quantity<=10?' low':'')+'">бҠӯбҲқбүҪбүө: '+p.quantity+'</div>';
      html+='<div class="pg-actions">';
      html+='<button class="pg-btn e" data-edit="'+p.id+'">вңҸпёҸ</button>';
      html+='<button class="pg-btn d" data-del="'+p.id+'">рҹ—‘пёҸ</button>';
      html+='</div></div>';
    });
    html+='</div>';
  }
  return html;
}

function rCatGrid(){
  var html='<div class="fr" style="margin-bottom:14px"><div style="font-size:15px;font-weight:800">рҹҢҝ бҲқбӢөбүҰбүҪ</div>'+
    '<button class="btn p" id="add-cat-btn" style="font-size:12px;padding:7px 12px">+ бҠ бӢІбҲө бҲқбӢөбүҘ</button></div>';
  html+='<div class="cat-grid">';
  CATS.forEach(function(c){
    var cnt=S.products.filter(function(p){return p.category===c.id;}).length;
    var expCnt=S.products.filter(function(p){var es=expStatus(p.expDate);return p.category===c.id&&es&&(es.status==='expired'||es.status==='soon');}).length;
    var isCustom=c.id.startsWith('cat_');
    html+='<div class="cat-card" data-cat="'+c.id+'" style="border-color:'+c.color+'33;position:relative">';
    if(isCustom) html+='<button class="cat-del-btn" data-delcat="'+c.id+'" style="position:absolute;top:6px;right:6px;z-index:2">вң•</button>';
    html+='<div class="cat-icon">'+c.icon+'</div>';
    html+='<div class="cat-name" style="color:'+c.color+'">'+c.name+(expCnt>0?' <span class="badge exp">вҡ пёҸ'+expCnt+'</span>':'')+'</div>';
    html+='<div class="cat-count">'+cnt+' бӢ•бүғ</div></div>';
  });
  html+='</div>';
  return html;
}

function rCatForm(){
  var f=S.catF;
  var html='<div class="mbg" id="catfmb"><div class="mod">';
  html+='<div class="mt">вһ• бҠ бӢІбҲө бҲқбӢөбүҘ</div>';
  html+='<div class="lbl">бӢЁбҲқбӢөбүЎ бҲөбҲқ</div>';
  html+='<input class="inp" id="cat-name" type="text" placeholder="бҲҲбҲқбҲібҲҢ: бҚҲбҠ•бҢҠбҲібӢӯбӢө" value="'+f.name+'"/>';
  html+='<div class="lbl">Icon бҲқбҲЁбҢҘ</div>';
  html+='<div class="icon-grid">';
  CAT_ICONS.forEach(function(ic,i){
    html+='<div class="icon-opt'+(f.icon===ic?' sel':'')+'" data-icon="'+ic+'">'+ic+'</div>';
  });
  html+='</div>';
  html+='<div class="lbl">бүҖбҲҲбҲқ бҲқбҲЁбҢҘ</div>';
  html+='<div class="color-grid">';
  CAT_COLORS.forEach(function(c,i){
    html+='<div class="color-opt'+(f.colorIdx===i?' sel':'')+'" data-colidx="'+i+'" style="background:'+c.color+'"></div>';
  });
  html+='</div>';
  // Preview
  var col=CAT_COLORS[f.colorIdx]||CAT_COLORS[0];
  html+='<div style="background:'+col.bg+';border:2px solid '+col.color+'33;border-radius:14px;padding:14px;text-align:center;margin-bottom:14px">';
  html+='<div style="font-size:28px">'+f.icon+'</div>';
  html+='<div style="font-weight:700;color:'+col.color+';margin-top:4px">'+(f.name||'бҲқбӢөбүҘ бҲөбҲқ')+'</div></div>';
  html+='<div class="ma"><button class="btn g" id="cat-cancel" style="flex:1">бҲ°бҲӯбӢқ</button><button class="btn p" id="cat-save" style="flex:2">рҹ’ҫ бҠ бҲөбүҖбҲқбҢҘ</button></div>';
  html+='</div></div>';
  return html;
}

function rSales(){
  var html='<div class="fr">'+
    '<div style="font-size:15px;font-weight:800">рҹ’° бҲҪбӢ«бҢ®бүҪ ('+S.sales.length+')</div>'+
    '<button class="btn p" id="as-btn" style="font-size:12px;padding:8px 12px">+ бҲҪбӢ«бҢӯ</button>'+
    '</div>';
  html+='<input class="inp" id="ss" placeholder="бҲҪбӢ«бҢӯ бҚҲбҲҚбҢҚ..." value="'+S.sSearch+'" style="margin-bottom:10px"/>';
  var filtered=S.sales.filter(function(s){return s.productName.includes(S.sSearch)||s.date.includes(S.sSearch);});
  if(filtered.length===0){html+='<div class="empty">бҲҪбӢ«бҢӯ бҠ бҲҚбү°бҢҲбҠҳбҲқ</div>';}
  else filtered.slice().reverse().forEach(function(s){
    var pr=S.products.find(function(p){return p.id===s.productId;});
    var prof=pr?(s.price-pr.buyPrice)*s.qty:0;
    html+='<div class="si">';
    html+='<div class="sh"><div><div class="sn">'+s.productName+'</div><div class="sm">'+s.date+' В· '+s.qty+' '+(pr?pr.unit:'бүҒ')+' Г— '+ETB(s.price)+'</div></div>';
    html+='<div style="text-align:right"><div class="st2">'+ETB(s.total)+'</div><div class="sp">бүөбҲӯбҚҚ: '+ETB(prof)+'</div></div></div>';
    // Edit + Delete buttons for sale
    html+='<div class="sact">';
    html+='<button class="btn g" style="flex:1;font-size:12px;padding:6px" data-edit-sale="'+s.id+'">вңҸпёҸ бҠ бҲөбү°бҠ«бҠӯбҲҚ</button>';
    html+='<button class="btn d" style="flex:1;font-size:12px;padding:6px" data-del-sale="'+s.id+'">рҹ—‘пёҸ бҲ°бҲӯбӢқ</button>';
    html+='</div></div>';
  });
  return html;
}

function rReport(d){
  var html='<div style="font-size:15px;font-weight:800;margin-bottom:12px">рҹ“Ҡ бҲӘбҚ–бҲӯбүө</div>';

  // Google Drive Sync card
  html+='<div class="'+(gdToken?(S.gdError?'sync-bar err':'sync-bar ok'):'sync-bar')+'">';
  if(gdToken){
    html+='<div class="sync-info">';
    html+='<div class="sync-title">вҳҒпёҸ Google Drive '+(S.gdError?'вқҢ':'вң…')+'</div>';
    html+='<div style="color:#6B7280;font-size:11px;margin-top:2px">'+(S.gdError?S.gdError:(S.gdSyncing?'рҹ”„ бҠҘбӢЁбү°бүҖбҲҳбҢ ...':(S.gdLastSync?'бҲҳбҢЁбҲЁбҲ»: '+S.gdLastSync:'бү°бӢҳбҢӢбҢ…бү·бҲҚ')))+'</div>';
    html+='</div>';
    html+='<div style="display:flex;flex-direction:column;gap:5px">';
    html+='<button class="gdrive-btn connected" id="gd-up" style="font-size:11px;padding:6px 10px">'+(S.gdSyncing?'рҹ”„':'в¬ҶпёҸ')+' бҠ бҲөбүҖбҲқбҢҘ</button>';
    html+='<button class="gdrive-btn" id="gd-down" style="font-size:11px;padding:6px 10px;background:linear-gradient(135deg,#0284C7,#0369A1)">в¬ҮпёҸ бҢ«бҠ•</button>';
    html+='<button class="btn g" id="gd-out" style="font-size:10px;padding:4px 8px">бӢқбҢӢ</button>';
    html+='</div>';
  } else {
    html+='<div class="sync-info">';
    html+='<div class="sync-title">вҳҒпёҸ Google Drive Backup</div>';
    html+='<div style="color:#6B7280;font-size:11px;margin-top:2px">бҲөбҲҚбҠӯ бүўбҢ бҚӢ бӢҚбҲӮбүҘбӢҺ бӢӯбҢ бү бүғбҲҚ</div>';
    html+='</div>';
    html+='<button class="gdrive-btn" id="gd-signin"><span style="font-size:16px">G</span> бҢҚбҠ“бҠҳ</button>';
  }
  html+='</div>';

  // Export/Import card
  html+='<div class="card" style="background:#F0FDF4;border-color:#16A34A33;margin-bottom:12px">';
  html+='<div class="st">рҹ’ҫ Manual Backup</div>';
  html+='<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">';
  html+='<button class="btn p" id="exp-json" style="flex:1;min-width:120px">рҹ“Ҙ JSON бӢҲбҲӯбӢө</button>';
  html+='<button class="btn g" id="exp-csv" style="flex:1;min-width:120px">рҹ“Ҡ CSV бӢҲбҲӯбӢө</button>';
  html+='</div>';
  html+='<div style="margin-top:10px"><label class="btn g" style="flex:1;display:block;text-align:center;padding:9px;border-radius:10px;cursor:pointer;font-size:13px;font-weight:700">рҹ“Ө JSON бҢ«бҠ• (Import)<input type="file" id="imp-file" accept=".json" style="display:none"/></label></div>';
  html+='</div>';

  html+='<div class="card"><div class="st">бҢ бү…бҲӢбҲӢ бҲӮбҲібүҘ</div>';
  [['бӢ•бүғ бӢ“бӢӯбҠҗбү¶бүҪ',S.products.length+' бӢ“бӢӯбҠҗбүө'],
   ['бҢ бү…бҲӢбҲӢ бӢ•бүғ',S.products.reduce(function(s,p){return s+p.quantity;},0)+' бүҒ'],
   ['бӢЁбӢ•бүғ бӢӢбҢӢ',ETB(d.inv)],
   ['бҲҪбӢ«бҢ®бүҪ',S.sales.length+' бҢҠбӢң'],
   ['бҢ бү…бҲӢбҲӢ бҲҪбӢ«бҢӯ',ETB(d.rev)],
   ['бүөбҲӯбҚҚ',ETB(d.prof)]
  ].forEach(function(r){html+='<div class="rr"><span>'+r[0]+'</span><span>'+r[1]+'</span></div>';});
  html+='</div>';
  html+='<div class="card"><div class="st">рҹ“Ұ бү бҲқбӢөбүҘ</div>';
  CATS.forEach(function(c){
    var ps=S.products.filter(function(p){return p.category===c.id;});
    var rev=S.sales.filter(function(s){return ps.find(function(p){return p.id===s.productId;});}).reduce(function(a,s){return a+s.total;},0);
    html+='<div class="rr"><span>'+c.icon+' '+c.name+'</span><span>'+ps.length+' бӢ•бүғ В· <span style="color:#16A34A">'+ETB(rev)+'</span></span></div>';
  });
  html+='</div>';
  if(d.expAlert.length>0){
    html+='<div class="exp-banner"><div class="etitle">вҡ пёҸ бҢҠбӢң бҠҘбӢ«бҲҲбүҖ бӢ«бҲү ('+d.expAlert.length+')</div>';
    d.expAlert.forEach(function(p){var es=expStatus(p.expDate);html+='<div class="exp-row"><span>'+p.name+'</span><span class="badge '+(es.status==='expired'?'exp':'soon')+'">'+es.label+'</span></div>';});
    html+='</div>';
  }
  return html;
}

function rTrash(){
  var tr=S.trash;
  var html='<div style="font-size:15px;font-weight:800;margin-bottom:8px">рҹ—‘пёҸ бүібҲӘбҠӯ ('+tr.length+')</div>';
  if(tr.length===0){html+='<div class="empty">бӢЁбү°бҲ°бҲЁбӢҳ бӢ•бүғ бӢЁбҲҲбҲқ</div>';return html;}
  html+='<div style="font-size:12px;color:#6B7280;margin-bottom:12px">вҶ©пёҸ бӢ•бүғ бӢӯбҲҳбҲҲбҲібҲҚ &nbsp;В·&nbsp; вқҢ бҲҷбҲү бҲ°бҲӯбӢқ</div>';
  tr.slice().reverse().forEach(function(p){
    var cat=getCat(p.category);
    html+='<div class="pi" style="background:#FFF8F0;border-color:#FED7AA">';
    html+='<div class="pic" style="background:'+cat.bg+'">'+cat.icon+'</div>';
    html+='<div class="pinfo"><div class="pname">'+p.name+'</div>';
    html+='<div class="pcat">'+cat.name+' В· '+ETB(p.sellPrice)+'</div>';
    html+='<div class="pqty" style="color:#EA580C">бү°бҲ°бҲӯбӢҳбӢӢбҲҚ: '+p.deletedAt+'</div></div>';
    html+='<div class="pact">';
    html+='<button class="ib" style="background:#DCFCE7;font-size:15px" data-restore="'+p.id+'">вҶ©пёҸ</button>';
    html+='<button class="ib dl" data-perm="'+p.id+'">вқҢ</button>';
    html+='</div></div>';
  });
  return html;
}

function rDetailMod(){
  var p=S.detailP;
  if(!p) return '';
  var cat=getCat(p.category);
  var es=expStatus(p.expDate);
  var html='<div class="mbg" id="dtlbg"><div class="mod">';
  html+='<div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">';
  html+='<div style="width:48px;height:48px;border-radius:12px;background:'+cat.bg+';display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0">'+cat.icon+'</div>';
  html+='<div><div style="font-size:17px;font-weight:800">'+p.name+'</div><div style="font-size:12px;color:#6B7280">'+cat.name+'</div></div></div>';
  // price big
  html+='<div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:12px;padding:12px 16px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center">';
  html+='<div><div style="font-size:11px;color:#6B7280">бӢЁбҲҪбӢ«бҢӯ бӢӢбҢӢ</div><div style="font-size:22px;font-weight:800;color:#16A34A">'+ETB(p.sellPrice)+'</div><div style="font-size:10px;color:#6B7280">/ '+p.unit+'</div></div>';
  html+='<div style="text-align:right"><div style="font-size:11px;color:#6B7280">бӢЁбҢҚбӢҘ бӢӢбҢӢ</div><div style="font-size:16px;font-weight:700;color:#15803D">'+ETB(p.buyPrice)+'</div></div></div>';
  // details
  html+='<div class="card" style="margin-bottom:12px">';
  html+='<div class="detail-row"><span class="detail-label">бҠӯбҲқбүҪбүө</span><span class="detail-val'+(p.quantity<=10?' wv':'')+'">'+p.quantity+' '+p.unit+'</span></div>';
  if(p.expDate){
    html+='<div class="detail-row"><span class="detail-label">рҹ“… Exp Date</span><span class="detail-val '+(es?es.status:'ok')+'">'+(es?es.label:p.expDate)+'</span></div>';
  }
  html+='</div>';
  // description
  if(p.desc){
    html+='<div style="font-size:12px;font-weight:600;color:#6B7280;margin-bottom:6px">рҹ“Ӣ бҠ бҢ бүғбүҖбҲқ / бҲӣбүҘбҲ«бҲӘбӢ«</div>';
    html+='<div class="desc-box">'+p.desc+'</div>';
  }
  html+='<div class="ma" style="margin-top:16px">';
  html+='<button class="btn g" id="dtl-close" style="flex:1">бӢқбҢӢ</button>';
  html+='<button class="btn p" data-edit="'+p.id+'" id="dtl-edit" style="flex:2">вңҸпёҸ бҠ бҲөбү°бҠ«бҠӯбҲҚ</button>';
  html+='</div></div></div>';
  return html;
}

function rPMod(){
  var f=S.pF;
  var html='<div class="mbg" id="pmb"><div class="mod">';
  html+='<div class="mt">'+(S.editP?'вңҸпёҸ бӢ•бүғ бҠ бҲөбү°бҠ«бҠӯбҲҚ':'вһ• бҠ бӢІбҲө бӢ•бүғ')+'</div>';
  html+='<div class="lbl">бӢЁбӢ•бүғ бҲөбҲқ</div><input class="inp pfi" data-k="name" type="text" placeholder="бҲҲбҲқбҲібҲҢ: бҲ«бӢҚбҠ•бӢө бҠ бҚ•" value="'+(f.name||'')+'"/>';
  html+='<div class="lbl">бҲқбӢөбүҘ</div><select class="inp pfi" data-k="category">';
  CATS.forEach(function(c){html+='<option value="'+c.id+'"'+(f.category===c.id?' selected':'')+'>'+c.icon+' '+c.name+'</option>';});
  html+='</select>';
  html+='<div class="lbl">бүҘбӢӣбүө</div><input class="inp pfi" data-k="quantity" type="number" placeholder="0" value="'+(f.quantity||'')+'"/>';
  html+='<div class="lbl">бӢЁбҢҚбӢҘ бӢӢбҢӢ (бүҘбҲӯ)</div><input class="inp pfi" data-k="buyPrice" type="number" placeholder="0" value="'+(f.buyPrice||'')+'"/>';
  html+='<div class="lbl">бӢЁбҲҪбӢ«бҢӯ бӢӢбҢӢ (бүҘбҲӯ)</div><input class="inp pfi" data-k="sellPrice" type="number" placeholder="0" value="'+(f.sellPrice||'')+'"/>';
  html+='<div class="lbl">бҲҳбҲҲбҠӘбӢ«</div><input class="inp pfi" data-k="unit" type="text" placeholder="бҲҠ / бҠӘ.бҢҚ / бҠЁбҲЁбҢўбүө" value="'+(f.unit||'')+'"/>';
  html+='<div class="lbl">рҹ“… Exp Date (бҢҠбӢң бҲӣбҲҲбүӮбӢ«) вҖ” бҠ бҲӣбҲ«бҢӯ</div><input class="inp pfi" data-k="expDate" type="date" value="'+(f.expDate||'')+'"/>';
  html+='<div class="lbl">рҹ“Ӣ бҠ бҢ бүғбүҖбҲқ / бҲӣбүҘбҲ«бҲӘбӢ« вҖ” бҠ бҲӣбҲ«бҢӯ</div><textarea class="inp pfi" data-k="desc" rows="3" placeholder="бӢЁбҲҳбӢөбҲғбҠ’бүұ бҠ бҢ бүғбүҖбҲқбҚЈ бҲҳбҢ бҠ•бҚЈ бҲӣбҲөбҢ бҠ•бүҖбүӮбӢ«...">'+(f.desc||'')+'</textarea>';
  html+='<div class="ma"><button class="btn g" id="pc" style="flex:1">бҲ°бҲӯбӢқ</button><button class="btn p" id="ps2" style="flex:2">рҹ’ҫ бҠ бҲөбүҖбҲқбҢҘ</button></div>';
  html+='</div></div>';
  return html;
}

function rSMod(){
  var f=S.sF;
  var pr=S.products.find(function(p){return p.id===f.productId;});
  var tot=pr&&f.qty?pr.sellPrice*+f.qty:0;
  var html='<div class="mbg" id="smb"><div class="mod">';
  html+='<div class="mt">'+(S.editS?'вңҸпёҸ бҲҪбӢ«бҢӯ бҠ бҲөбү°бҠ«бҠӯбҲҚ':'рҹ’° бҲҪбӢ«бҢӯ бҲқбӢқбҢҲбүЈ')+'</div>';
  html+='<div class="lbl">бӢ•бүғ бҲқбҲЁбҢҘ</div><select class="inp" id="sp">';
  html+='<option value="">-- бӢ•бүғ бҲқбҲЁбҢҘ --</option>';
  CATS.forEach(function(c){
    var ps=S.products.filter(function(p){return p.category===c.id;});
    if(ps.length>0){
      html+='<optgroup label="'+c.icon+' '+c.name+'">';
      ps.forEach(function(p){html+='<option value="'+p.id+'"'+(f.productId===p.id?' selected':'')+'>'+p.name+' ('+p.quantity+' '+p.unit+') вҖ” '+ETB(p.sellPrice)+'</option>';});
      html+='</optgroup>';
    }
  });
  html+='</select>';
  html+='<div class="lbl">бүҘбӢӣбүө</div><input class="inp" id="sq" type="number" placeholder="0" value="'+(f.qty||'')+'"/>';
  html+='<div class="lbl">бүҖбҠ•</div><input class="inp" id="sd" type="date" value="'+f.date+'"/>';
  if(tot>0) html+='<div class="tp">рҹ’° бҢ бү…бҲӢбҲӢ: <strong>'+ETB(tot)+'</strong></div>';
  html+='<div class="ma"><button class="btn g" id="sc2" style="flex:1">бҲ°бҲӯбӢқ</button><button class="btn p" id="ss2" style="flex:2">рҹ’ҫ '+(S.editS?'бҠ бӢҳбҲқбҠ•':'бҲқбӢқбҢҲбүҘ')+'</button></div>';
  html+='</div></div>';
  return html;
}

function rConfDel(){
  return '<div class="cmod-bg" id="cb"><div class="cmod">'+
    '<div class="bi">рҹ—‘пёҸ</div><h3>"'+S.confDel.name+'" бӢӯбҲ°бҲӯбӢҷ?</h3>'+
    '<p>бӢҲбӢ° бүібҲӘбҠӯ бӢӯбҲ„бӢібҲҚ вҖ” бҲҳбҲҚбҲ¶ бҲӣбҲқбҢЈбүө бӢӯбү»бҲӢбҲҚбҚў</p>'+
    '<div class="ca"><button class="btn g" id="cc" style="flex:1">бҲ°бҲӯбӢқ</button><button class="btn d" id="co" style="flex:1">бҠ бӢҺ</button></div>'+
    '</div></div>';
}
function rConfDelSale(){
  return '<div class="cmod-bg" id="csb"><div class="cmod">'+
    '<div class="bi">рҹ—‘пёҸ</div><h3>бҲҪбӢ«бҢӯ бӢӯбҲ°бҲӯбӢҷ?</h3>'+
    '<p>бҠӯбҲқбүҪбүұ бү°бҲҳбҲҚбҲ¶ бӢӯбҢЁбҲҳбҲ«бҲҚбҚў</p>'+
    '<div class="ca"><button class="btn g" id="csc" style="flex:1">бҲ°бҲӯбӢқ</button><button class="btn d" id="cso" style="flex:1">бҠ бӢҺ</button></div>'+
    '</div></div>';
}

// в”Җв”Җ Bind в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function bindLogin(){
  if(S.loginStep==='pin-set'){
    document.getElementById('pin1')?.addEventListener('input',function(e){S.pinVal=e.target.value;S.pinErr='';});
    document.getElementById('pin2')?.addEventListener('input',function(e){S.pinConfirm=e.target.value;S.pinErr='';});
    document.getElementById('pin2')?.addEventListener('keydown',function(e){if(e.key==='Enter')loginSetPin();});
    document.getElementById('pin-set-btn')?.addEventListener('click',loginSetPin);
    document.getElementById('pin-back')?.addEventListener('click',function(){set({loginStep:'id',pinVal:'',pinConfirm:'',pinErr:''});});
    return;
  }
  if(S.loginStep==='pin-enter'){
    document.getElementById('pin-e')?.addEventListener('input',function(e){S.pinVal=e.target.value;S.pinErr='';});
    document.getElementById('pin-e')?.addEventListener('keydown',function(e){if(e.key==='Enter')loginEnterPin();});
    document.getElementById('pin-enter-btn')?.addEventListener('click',loginEnterPin);
    document.getElementById('pin-back')?.addEventListener('click',function(){set({loginStep:'id',pinVal:'',pinErr:''});});
    return;
  }
  document.getElementById('li').addEventListener('input',function(e){S.loginVal=e.target.value;S.loginErr='';});
  document.getElementById('li').addEventListener('keydown',function(e){if(e.key==='Enter')login();});
  document.getElementById('lb').addEventListener('click',login);
}
function bindMain(){
  document.getElementById('ob')?.addEventListener('click',logout);
  document.getElementById('install-btn')?.addEventListener('click',triggerInstall);
  if(deferredPrompt) showInstallBar();
  // Google Drive
  document.getElementById('gd-signin')?.addEventListener('click',gdSignIn);
  document.getElementById('gd-up')?.addEventListener('click',gdSyncUp);
  document.getElementById('gd-down')?.addEventListener('click',gdSyncDown);
  document.getElementById('gd-out')?.addEventListener('click',gdSignOut);
  document.getElementById('rem-drive')?.addEventListener('click',function(){dismissReminder();set({tab:'report'});});
  document.getElementById('rem-dismiss')?.addEventListener('click',dismissReminder);
  // export
  document.getElementById('exp-json')?.addEventListener('click',exportJSON);
  document.getElementById('exp-csv')?.addEventListener('click',exportCSV);
  document.getElementById('imp-file')?.addEventListener('change',function(e){if(e.target.files[0])importJSON(e.target.files[0]);});
  document.querySelectorAll('[data-tab]').forEach(function(b){b.addEventListener('click',function(){set({tab:b.dataset.tab,selCat:null});});});
  // cat grid
  document.getElementById('add-cat-btn')?.addEventListener('click',function(){set({showCatForm:true,catF:{name:'',icon:'рҹҢ»',colorIdx:0}});});
  document.querySelectorAll('[data-delcat]').forEach(function(b){b.addEventListener('click',function(e){e.stopPropagation();if(confirm('"'+getCat(b.dataset.delcat).name+'" бҲқбӢөбүҘ бӢӯбҲ°бҲӯбӢҷ?'))delCat(b.dataset.delcat);});});
  // cat form
  document.getElementById('cat-name')?.addEventListener('input',function(e){S.catF.name=e.target.value;render();});
  document.querySelectorAll('[data-icon]').forEach(function(b){b.addEventListener('click',function(){S.catF.icon=b.dataset.icon;render();});});
  document.querySelectorAll('[data-colidx]').forEach(function(b){b.addEventListener('click',function(){S.catF.colorIdx=parseInt(b.dataset.colidx);render();});});
  document.getElementById('cat-save')?.addEventListener('click',saveCat);
  document.getElementById('cat-cancel')?.addEventListener('click',function(){set({showCatForm:false});});
  document.getElementById('catfmb')?.addEventListener('click',function(e){if(e.target.id==='catfmb')set({showCatForm:false});});
  // cat nav
  document.querySelectorAll('[data-cat]').forEach(function(b){b.addEventListener('click',function(){set({selCat:b.dataset.cat,pSearch:'',showPForm:false});});});
  document.getElementById('back-cat')?.addEventListener('click',function(){set({selCat:null,pSearch:''});});
  // inv
  document.getElementById('ap-btn')?.addEventListener('click',function(){set({showPForm:true,editP:null,pF:{name:'',category:S.selCat||'arem',quantity:'',buyPrice:'',sellPrice:'',unit:'бҲҠ',expDate:''}});});
  document.getElementById('ps')?.addEventListener('input',function(e){set({pSearch:e.target.value});});
  // detail card click
  document.querySelectorAll('[data-detail]').forEach(function(b){
    b.addEventListener('click',function(e){
      // don't trigger if edit/del btn clicked
      if(e.target.closest('[data-edit]')||e.target.closest('[data-del]')) return;
      var p=S.products.find(function(x){return x.id===b.dataset.detail;});
      if(p) set({detailP:p});
    });
  });
  document.getElementById('dtl-close')?.addEventListener('click',function(){set({detailP:null});});
  document.getElementById('dtl-edit')?.addEventListener('click',function(){
    var p=S.detailP;
    if(p){set({detailP:null,showPForm:true,editP:p,pF:{name:p.name,category:p.category,quantity:p.quantity,buyPrice:p.buyPrice,sellPrice:p.sellPrice,unit:p.unit,expDate:p.expDate||'',desc:p.desc||''}});}
  });
  document.getElementById('dtlbg')?.addEventListener('click',function(e){if(e.target.id==='dtlbg')set({detailP:null});});
  document.querySelectorAll('[data-edit]').forEach(function(b){b.addEventListener('click',function(e){e.stopPropagation();var p=S.products.find(function(x){return x.id===b.dataset.edit;});if(p)set({showPForm:true,editP:p,pF:{name:p.name,category:p.category,quantity:p.quantity,buyPrice:p.buyPrice,sellPrice:p.sellPrice,unit:p.unit,expDate:p.expDate||'',desc:p.desc||''}});});});
  document.querySelectorAll('[data-del]').forEach(function(b){b.addEventListener('click',function(e){e.stopPropagation();var p=S.products.find(function(x){return x.id===b.dataset.del;});if(p)set({confDel:p});});});
  // prod form
  document.querySelectorAll('.pfi').forEach(function(i){i.addEventListener('input',function(e){S.pF[e.target.dataset.k]=e.target.value;});});
  document.getElementById('pc')?.addEventListener('click',function(){set({showPForm:false});});
  document.getElementById('ps2')?.addEventListener('click',saveProd);
  document.getElementById('pmb')?.addEventListener('click',function(e){if(e.target.id==='pmb')set({showPForm:false});});
  // sales
  document.getElementById('as-btn')?.addEventListener('click',function(){set({showSForm:true,editS:null,sF:{productId:'',qty:'',date:today()}});});
  document.getElementById('ss')?.addEventListener('input',function(e){set({sSearch:e.target.value});});
  // sale edit/delete
  document.querySelectorAll('[data-edit-sale]').forEach(function(b){b.addEventListener('click',function(){
    var s=S.sales.find(function(x){return x.id===b.dataset.editSale;});
    if(s)set({showSForm:true,editS:s.id,sF:{productId:s.productId,qty:s.qty,date:s.date}});
  });});
  document.querySelectorAll('[data-del-sale]').forEach(function(b){b.addEventListener('click',function(){
    var s=S.sales.find(function(x){return x.id===b.dataset.delSale;});
    if(s)set({confDelSale:s});
  });});
  // sale form
  document.getElementById('sp')?.addEventListener('change',function(e){S.sF.productId=e.target.value;render();});
  document.getElementById('sq')?.addEventListener('input',function(e){S.sF.qty=e.target.value;render();});
  document.getElementById('sd')?.addEventListener('input',function(e){S.sF.date=e.target.value;});
  document.getElementById('sc2')?.addEventListener('click',function(){set({showSForm:false,editS:null});});
  document.getElementById('ss2')?.addEventListener('click',saveSale);
  document.getElementById('smb')?.addEventListener('click',function(e){if(e.target.id==='smb')set({showSForm:false,editS:null});});
  // confirm del prod
  document.getElementById('cc')?.addEventListener('click',function(){set({confDel:null});});
  document.getElementById('co')?.addEventListener('click',function(){delProd(S.confDel.id);});
  document.getElementById('cb')?.addEventListener('click',function(e){if(e.target.id==='cb')set({confDel:null});});
  // confirm del sale
  document.getElementById('csc')?.addEventListener('click',function(){set({confDelSale:null});});
  document.getElementById('cso')?.addEventListener('click',function(){delSale(S.confDelSale.id);});
  document.getElementById('csb')?.addEventListener('click',function(e){if(e.target.id==='csb')set({confDelSale:null});});
  // trash
  document.querySelectorAll('[data-restore]').forEach(function(b){b.addEventListener('click',function(){restoreProd(b.dataset.restore);});});
  document.querySelectorAll('[data-perm]').forEach(function(b){b.addEventListener('click',function(){permDel(b.dataset.perm);});});
}

// в”Җв”Җ Install prompt в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
var deferredPrompt=null;
window.addEventListener('beforeinstallprompt',function(e){
  e.preventDefault();
  deferredPrompt=e;
  showInstallBar();
});
window.addEventListener('appinstalled',function(){
  hideInstallBar();
  deferredPrompt=null;
  showToast('вң… бҠ бҚ‘ бү°бҢӯбҠ—бҲҚ!');
});
function showInstallBar(){
  var bar=document.getElementById('install-bar');
  if(bar) bar.style.display='flex';
}
function hideInstallBar(){
  var bar=document.getElementById('install-bar');
  if(bar) bar.style.display='none';
}
function triggerInstall(){
  if(!deferredPrompt){
    showToast('рҹ“ұ Browser вӢ® вҶ’ "Add to Home Screen" бү°бҢ«бҠ•');
    return;
  }
  deferredPrompt.prompt();
  deferredPrompt.userChoice.then(function(r){
    if(r.outcome==='accepted') showToast('вң… бҠ бҚ‘ бҠҘбӢЁбү°бҢ«бҠҗ бҠҗбӢҚ!');
    deferredPrompt=null;
    hideInstallBar();
  });
}

// в”Җв”Җ PWA в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if('serviceWorker' in navigator){
  var sw="const C='grb-v2';self.addEventListener('install',e=>{e.waitUntil(caches.open(C).then(c=>c.addAll(['/'])));self.skipWaiting();});self.addEventListener('fetch',e=>{e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request).catch(()=>caches.match('/'))));});";
  navigator.serviceWorker.register(URL.createObjectURL(new Blob([sw],{type:'application/javascript'}))).catch(function(){});
}
// Generate proper PNG icon using canvas
var canvas=document.createElement('canvas');
canvas.width=512;canvas.height=512;
var ctx=canvas.getContext('2d');
// Green background circle
var grad=ctx.createLinearGradient(0,0,512,512);
grad.addColorStop(0,'#16A34A');
grad.addColorStop(1,'#15803D');
ctx.fillStyle=grad;
ctx.beginPath();
ctx.roundRect(0,0,512,512,80);
ctx.fill();
// Emoji
ctx.font='320px serif';
ctx.textAlign='center';
ctx.textBaseline='middle';
ctx.fillText('рҹҢұ',256,270);
// Shop name
ctx.font='bold 64px sans-serif';
ctx.fillStyle='#ffffff';
ctx.fillText('бҢҚбүҘбҲӯбҠ“',256,430);
var iconUrl=canvas.toDataURL('image/png');
var mf={name:'бҢҚбүҘбҲӯбҠ“ бҲұбү…',short_name:'бҢҚбүҘбҲӯбҠ“',start_url:'.',display:'standalone',background_color:'#16A34A',theme_color:'#16A34A',
  icons:[
    {src:iconUrl,sizes:'192x192',type:'image/png'},
    {src:iconUrl,sizes:'512x512',type:'image/png'}
  ]
};
document.getElementById('mp').href=URL.createObjectURL(new Blob([JSON.stringify(mf)],{type:'application/manifest+json'}));
// Also set apple touch icon
var link=document.createElement('link');
link.rel='apple-touch-icon';
link.href=iconUrl;
document.head.appendChild(link);

// в”Җв”Җ Init в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
var sv=localStorage.getItem('grb_session');
if(sv&&getPin(sv)){
  // Has PIN вҖ” require re-entry for security
  S.loginStep='pin-enter';S.pendingUser=sv;
} else if(sv){
  // Old account without PIN вҖ” load directly (backwards compat)
  var d=loadData(sv);S.user=sv;S.products=d?d.products:DEMO.products;S.sales=d?d.sales:DEMO.sales;S.trash=d?d.trash||[]:[]; 
}
render();
</script>
</body>
</html>
